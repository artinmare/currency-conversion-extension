{
  "manifest_version": 3,
  "name": "Currency Converter",
  "version": "1.0",
  "description": "Highlight text to check and convert currencies",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://api.frankfurter.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Currency Converter"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
